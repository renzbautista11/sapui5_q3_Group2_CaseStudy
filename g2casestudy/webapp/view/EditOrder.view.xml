<mvc:View controllerName="com.training.g2casestudy.controller.EditOrder"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="pageEditOrder" title="{i18n>title}" floatingFooter="true">
        <footer>
            <OverflowToolbar id="oftFooterEditOrder">
                <ToolbarSpacer id="tsfooterEditOrder"></ToolbarSpacer>
                <Button id="btnSave" text="{i18n>save}" type="Emphasized" press="onSave"/>
                <Button id="btnCancel" text="{i18n>cancel}" type="Reject" press="onCancel"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>